<configuration>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} [%-5level] %logger{0} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- your tree package specifically -->
    <logger name="io.github.youssefrashidy.Trees" level="DEBUG"/>

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>